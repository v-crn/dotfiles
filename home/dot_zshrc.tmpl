# ── Load modular zsh config ───────────────────────────────────────────────────
# Glob-source all *.zsh files in config dir. Load order is alphabetical;
# order-sensitive files use numeric prefixes (50_sheldon, 60_completion).
_zsh_config="${XDG_CONFIG_HOME:-$HOME/.config}/zsh"

for _f in "$_zsh_config"/*.zsh; do
    source "$_f"
done
unset _f _zsh_config
